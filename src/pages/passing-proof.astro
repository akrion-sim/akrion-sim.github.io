---
import Base from '../layouts/Base.astro';
const base = import.meta.env.BASE_URL;

// Headline vs guard metrics — the reframe that makes the proof tractable.
const headline = [
  { c: 'g', k: 'shots on target / goals', d: 'chance creation — the selection side of learning' },
  { c: 'b', k: 'completed forward passes', d: 'count, not rate — the execution side of learning' },
  { c: 'r', k: 'pass-turnover rate ↓', d: 'the real-world pain: passes to the opponent' },
];
const guards = [
  { k: 'completion %', d: 'must not drop while the count rises' },
  { k: 'yards per completed pass', d: 'catches short safe-poke inflation' },
  { k: 'route-one share', d: 'catches hoof-and-hope regressions' },
];

const halves = [
  {
    c: 'g', tag: 'proven', t: 'Selection · Dynamic programming',
    lead: 'Which option, and where the threat is.',
    body: 'A DP-value-iterated critic target teaches the net to rank the analytic engine’s options better and to value positions by real outcomes. This is the half a trained net can express — and it moves the un-ceilinged metrics.',
    why: 'A trained policy beats an untrained one at shots-on-target with three independent statistics all clearing 99.99%. Learning demonstrably creates chances.',
  },
  {
    c: 'b', tag: 'clean test pending', t: 'Execution · Model-predictive control',
    lead: 'How the pass is actually struck.',
    body: 'A learned MPC-objective head nudges the analytic aim and lead by a hard-bounded residual at execution time. Unlike the critic, it changes the ball’s flight, not just the choice — so it is the one learned lever that can move passing above the scaffold floor.',
    why: 'Because it acts at play time, it can be isolated exactly: toggle the head on vs. off on one frozen net over identical seeds. That within-net causal test — zero training noise — is the last piece.',
  },
];
---
<Base
  title="Proving the passing — Akrion Soccer Engine"
  description="Can neural + dynamic-programming + MPC learning genuinely raise passing? The honest state of a rigorous proof: what is proven at 99.99%, why the completion rate is scaffold-bound, and the clean causal test that isolates learned execution."
>
  <section class="section head">
    <div class="wrap">
      <p class="eyebrow">Research · proof in progress</p>
      <h1>Can learning raise <span class="grad">passing</span>?</h1>
      <p class="lede">
        Most of Akrion’s passing is hand-built: the analytic engine generates the
        options and model-predictive control strikes the ball. Proving that neural,
        dynamic-programming and MPC <em>learning</em> genuinely improves it — to
        99.99% confidence — means cleanly separating what the learner adds from what the
        scaffold already does. This is the honest state of that proof, kept falsifiable.
      </p>
    </div>
  </section>

  <hr class="hr" />

  <!-- THE REFRAME -->
  <section class="section">
    <div class="wrap">
      <div class="split">
        <div class="reveal">
          <p class="eyebrow">The reframe</p>
          <h2>The completion <em>rate</em> is the wrong target</h2>
          <p>
            Pass completion rate sits near <strong>92%</strong> and stays there — trained,
            untrained, or pure analytic. It is a ceiling set by the analytic engine and
            MPC, because the neural net only <em>re-ranks</em> the candidates it is offered.
            Chasing that scalar is chasing a number the learning does not control.
          </p>
          <p class="mono-note">Confirmed three independent ways: direct measurement, a matched null distribution, and a trained-vs-untrained lineage — all flat on rate.</p>
        </div>
        <div class="ceil reveal">
          <span class="topbar"></span>
          <p class="ceil-k mono">pass completion rate</p>
          <p class="ceil-v">~0.92<span class="ceil-flat">flat</span></p>
          <p class="ceil-d">Scaffold-bound. Demoted from headline to a <strong>guard</strong> — it must not drop while the movable metrics climb.</p>
        </div>
      </div>
    </div>
  </section>

  <hr class="hr" />

  <!-- WHAT'S PROVEN -->
  <section class="section">
    <div class="wrap">
      <div class="reveal" style="max-width:720px; margin-bottom:36px;">
        <p class="eyebrow">What is proven</p>
        <h2>Learning is real — at 99.99%</h2>
        <p class="lede">
          A trained policy played head-to-head against an <em>untrained</em> one (same
          architecture, zero gradient steps) on held-out seeds. The gap is unambiguous and
          survives every statistic we could throw at it.
        </p>
      </div>
      <div class="stat-row">
        <div class="stat reveal"><span class="stat-v grad">+0.488</span><span class="stat-k">shots on target / game</span><span class="stat-s">normal · bootstrap · sign-test all clear 99.99%</span></div>
        <div class="stat reveal"><span class="stat-v">+0.185</span><span class="stat-k">goals / game</span><span class="stat-s">3.3σ</span></div>
        <div class="stat reveal"><span class="stat-v">+0.515</span><span class="stat-k">shots / game</span><span class="stat-s">3.5σ</span></div>
      </div>
      <p class="mono-note reveal" style="text-align:center; margin-top:22px;">Neural + DP learning demonstrably moves real match outcomes — on the chance-creation side.</p>
    </div>
  </section>

  <hr class="hr" />

  <!-- METRIC HIERARCHY -->
  <section class="section">
    <div class="wrap">
      <div class="reveal" style="max-width:720px; margin-bottom:38px;">
        <p class="eyebrow">The metric hierarchy</p>
        <h2>Headline the metrics learning can move</h2>
        <p class="lede">
          If the rate is capped, headline the un-ceilinged quantities — and guard against
          the cheap way to fake them (recycling short, safe, backward passes). No single
          metric; a set that can’t all be gamed at once.
        </p>
      </div>
      <div class="mh">
        <div class="mh-col reveal">
          <p class="mh-h mh-head">Headline · movable</p>
          {headline.map((r) => (
            <div class={`mh-row accent-${r.c}`}><span class="topbar"></span><span class="mh-k">{r.k}</span><span class="mh-d">{r.d}</span></div>
          ))}
        </div>
        <div class="mh-col reveal">
          <p class="mh-h mh-guard">Guards · must not regress</p>
          {guards.map((r) => (
            <div class="mh-row guard"><span class="mh-k">{r.k}</span><span class="mh-d">{r.d}</span></div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <hr class="hr" />

  <!-- METHOD -->
  <section class="section">
    <div class="wrap">
      <div class="reveal" style="max-width:720px; margin-bottom:40px;">
        <p class="eyebrow">Method</p>
        <h2>Rigor over excitement</h2>
        <p class="lede">A proof is only as good as the traps it survives. Two mattered.</p>
      </div>
      <div class="grid grid-2">
        <article class="card accent-r reveal">
          <span class="topbar"></span>
          <div class="chead"><h3>The trap we caught</h3><span class="ctag">retracted</span></div>
          <p class="clead"><strong>An early result looked like a breakthrough.</strong> Training with the execution heads on seemed to swing forward-passing by +58 against the analytic baseline.</p>
          <p class="cwhy"><span class="why-k">Why it fell</span> Two <em>identical</em> control runs differed by the same magnitude — the effect was training nondeterminism (a per-process LP solver, parallel workers, a wall-clock budget), not the heads. Retracted rather than reported.</p>
        </article>
        <article class="card accent-b reveal">
          <span class="topbar"></span>
          <div class="chead"><h3>The clean test</h3><span class="ctag">causal</span></div>
          <p class="clead"><strong>The learned MPC-aim head acts at play time.</strong> So it can be isolated with no training noise at all: take one frozen net and toggle the head on vs. off, over identical seeds, with a deterministic solver.</p>
          <p class="cwhy"><span class="why-k">Why it is decisive</span> The only thing that differs between the two evals is whether the net uses its learned aim. The forward-completion and turnover-rate difference <em>is</em> the head’s causal effect — and it scales to 99.99% simply by adding held-out games.</p>
        </article>
      </div>
    </div>
  </section>

  <hr class="hr" />

  <!-- TWO HALVES -->
  <section class="section">
    <div class="wrap">
      <div class="reveal" style="max-width:760px; margin-bottom:44px;">
        <p class="eyebrow">Two halves of one claim</p>
        <h2>Selection is proven; execution is the last piece</h2>
        <p class="lede">
          Passing improvement splits cleanly by mechanism. The critic decides <em>which</em>
          pass; the MPC head decides <em>how</em> it is struck. Together they are the full
          neural + DP + MPC story.
        </p>
      </div>
      <div class="grid grid-2 concepts">
        {halves.map((x) => (
          <article class={`card accent-${x.c} reveal`}>
            <span class="topbar"></span>
            <div class="chead"><h3>{x.t}</h3><span class="ctag">{x.tag}</span></div>
            <p class="clead"><strong>{x.lead}</strong> {x.body}</p>
            <p class="cwhy"><span class="why-k">Status</span> {x.why}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <hr class="hr" />

  <!-- CLOSE -->
  <section class="section">
    <div class="wrap">
      <div class="cta-panel reveal">
        <h2>Optimal passing isn’t a rate you push — it’s the passes the learner adds that the scaffold never would.</h2>
        <div class="cta" style="justify-content:center;">
          <a class="btn btn-primary" href={`${base}learning`}>How the engine learns</a>
          <a class="btn btn-ghost" href={`${base}engine`}>Inside the engine</a>
          <a class="btn btn-ghost" href="https://github.com/akrion-sim" target="_blank" rel="noopener">GitHub ↗</a>
        </div>
      </div>
    </div>
  </section>
</Base>

<style>
  .head h1 { max-width: 16ch; }
  .grad { background: linear-gradient(100deg, var(--green-bright), var(--blue-bright)); -webkit-background-clip: text; background-clip: text; color: transparent; }
  .head .lede { margin-top: 18px; }

  .split { display: grid; grid-template-columns: 1.1fr 0.9fr; gap: 44px; align-items: center; }
  @media (max-width: 880px) { .split { grid-template-columns: 1fr; gap: 28px; } }
  .split p { color: var(--ink-soft); }

  .ceil { position: relative; border: 1px solid var(--line); border-radius: var(--radius); padding: 30px 30px 26px; overflow: hidden;
    background: radial-gradient(500px 240px at 80% 0%, rgba(239,68,68,0.12), transparent 60%), linear-gradient(180deg, var(--panel), var(--bg-2)); }
  .ceil .topbar { position: absolute; top: 0; left: 0; right: 0; height: 3px; background: var(--red-bright); }
  .ceil-k { font-size: 0.72rem; text-transform: uppercase; letter-spacing: 0.1em; color: var(--ink-dim); margin: 6px 0 4px; }
  .ceil-v { font-size: 3rem; font-weight: 800; letter-spacing: -0.02em; line-height: 1; margin: 0; display: flex; align-items: baseline; gap: 12px; }
  .ceil-flat { font-family: var(--font-mono); font-size: 0.7rem; letter-spacing: 0.12em; text-transform: uppercase; color: var(--red-bright); border: 1px solid color-mix(in srgb, var(--red) 45%, var(--line)); border-radius: 999px; padding: 4px 9px; }
  .ceil-d { color: var(--ink-soft); font-size: 0.92rem; margin: 16px 0 0; }

  .stat-row { display: grid; grid-template-columns: repeat(3, 1fr); gap: 18px; }
  @media (max-width: 720px) { .stat-row { grid-template-columns: 1fr; } }
  .stat { border: 1px solid var(--line); border-radius: var(--radius); padding: 26px 24px; background: linear-gradient(180deg, var(--panel), var(--bg-2)); display: flex; flex-direction: column; gap: 6px; }
  .stat-v { font-size: 2.4rem; font-weight: 800; letter-spacing: -0.02em; line-height: 1; }
  .stat-v.grad { background: linear-gradient(100deg, var(--green-bright), var(--blue-bright)); -webkit-background-clip: text; background-clip: text; color: transparent; }
  .stat-k { color: var(--ink); font-size: 0.98rem; }
  .stat-s { color: var(--ink-dim); font-family: var(--font-mono); font-size: 0.74rem; letter-spacing: 0.04em; }

  .mh { display: grid; grid-template-columns: 1fr 1fr; gap: 24px; align-items: start; }
  @media (max-width: 820px) { .mh { grid-template-columns: 1fr; } }
  .mh-h { font-family: var(--font-mono); font-size: 0.72rem; letter-spacing: 0.12em; text-transform: uppercase; margin: 0 0 14px; }
  .mh-head { color: var(--green-bright); }
  .mh-guard { color: var(--ink-dim); }
  .mh-col { display: grid; gap: 12px; }
  .mh-row { position: relative; overflow: hidden; display: grid; grid-template-columns: 190px 1fr; gap: 14px; align-items: center; border: 1px solid var(--line); border-radius: 12px; padding: 15px 18px; background: var(--bg-2); }
  .mh-row .topbar { position: absolute; top: 0; left: 0; right: 0; height: 3px; background: var(--a); }
  .mh-row.guard { border-style: dashed; opacity: 0.86; }
  .mh-k { font-weight: 650; color: var(--ink); font-size: 0.92rem; }
  .mh-d { color: var(--ink-soft); font-size: 0.85rem; }
  @media (max-width: 520px) { .mh-row { grid-template-columns: 1fr; gap: 4px; } }

  .concepts .card, .grid-2 .card { padding: 26px 28px; }
  .chead { display: flex; align-items: center; justify-content: space-between; gap: 12px; margin-bottom: 12px; }
  .chead h3 { margin: 0; }
  .ctag { font-family: var(--font-mono); font-size: 0.64rem; letter-spacing: 0.14em; text-transform: uppercase; color: var(--ab); border: 1px solid color-mix(in srgb, var(--a) 40%, var(--line)); background: color-mix(in srgb, var(--a) 10%, transparent); padding: 4px 9px; border-radius: 999px; white-space: nowrap; }
  .clead { color: var(--ink-soft); font-size: 0.96rem; }
  .clead strong { color: var(--ink); }
  .cwhy { color: var(--ink-soft); font-size: 0.92rem; margin: 0; padding-top: 14px; border-top: 1px solid var(--line-soft); }
  .why-k { display: inline-block; font-family: var(--font-mono); font-size: 0.66rem; letter-spacing: 0.12em; text-transform: uppercase; color: var(--ab); margin-right: 8px; }

  .cta-panel { text-align: center; padding: 52px 32px; border: 1px solid var(--line); border-radius: var(--radius-lg);
    background: radial-gradient(600px 300px at 30% 0%, rgba(34,197,94,0.14), transparent 60%), radial-gradient(600px 300px at 80% 100%, rgba(59,130,246,0.12), transparent 60%), linear-gradient(180deg, var(--panel), var(--bg-2)); }
  .cta-panel h2 { max-width: 26ch; margin: 0 auto 24px; }
</style>
