---
import Base from '../layouts/Base.astro';
const base = import.meta.env.BASE_URL;

const curriculum = ['locomotion', 'ball-skills', 'duels', 'small-sided', 'team-shape', 'full-match'];

const learners = [
  { c: 'g', t: 'Neural actor-critic', d: 'A threaded PPO learner trains the SoccerPolicyHead with GAE advantages and clipped multi-epoch updates. Per-role heads specialise for goalkeeper, defender, midfielder and forward.' },
  { c: 'g', t: 'Value / critic head', d: 'A neural critic estimates state value from transition rewards, giving the advantage estimate that tells the actor which decisions actually helped.' },
  { c: 'g', t: 'Skill specialists', d: 'Dedicated learned heads for passing, dribbling, shooting and goalkeeping — including a pass-completion head that blends into live play once it is warm enough to trust.' },
  { c: 'b', t: 'Line-depth models', d: 'Back-four and midfield line-depth heads learn where the defensive and midfield lines should sit, draining samples during play and gating consumption once trained.' },
  { c: 'r', t: 'Evolution / GA', d: 'Every ~10 games an evolutionary loop mutates, crosses over and keeps the elite of a small population — genetic search to escape the plateaus gradient descent settles into.' },
  { c: 'b', t: 'Config-similarity retrieval', d: 'An HNSW index over a 22-players-plus-ball embedding retrieves the nearest situations ever seen — instance-based memory that grounds novel states in real experience.' },
];

const reward = [
  { k: 'events', d: 'goals · completed passes · shots · possession chains', hot: true },
  { k: 'tactical shaping', d: 'width · line depth · cohesion · team shape' },
  { k: 'pitch value (gated)', d: 'pitch-control × expected-threat (xT) delta' },
];
---
<Base title="Learning & AI/ML — Akrion Soccer Engine" description="The reinforcement-learning system behind Akrion: self-play, PPO actor-critic, curriculum learning, evolutionary search, and continual adaptation to unseen opponents.">
  <section class="section head">
    <div class="wrap">
      <p class="eyebrow">Learning &amp; AI / ML</p>
      <h1>How the engine <span class="grad">learns to play</span></h1>
      <p class="lede">
        Akrion doesn’t ship a fixed strategy. It runs a continuous self-play loop that
        trains neural policies with reinforcement learning, grows skill through a
        curriculum, and uses evolutionary search to break past the ceilings that pure
        gradients hit. The goal is optimal control — reached by learning, and never
        frozen.
      </p>
    </div>
  </section>

  <hr class="hr" />

  <!-- SELF-PLAY LOOP -->
  <section class="section">
    <div class="wrap">
      <div class="reveal" style="max-width:720px; margin-bottom:40px;">
        <p class="eyebrow">The self-play loop</p>
        <h2>Play a match · reward the moments · update · repeat</h2>
        <p class="lede">
          The home policy plays the away policy. Every step is scored, every match feeds
          the learners, and the best policies are promoted through a quality gate to
          become the next opponent. The system is its own sparring partner.
        </p>
      </div>

      <div class="loop">
        <div class="loop-step accent-b reveal"><span class="ln mono">01</span><h3>Curriculum stage</h3><p>Sample a stage from locomotion up to full match, so skills are learned in order.</p></div>
        <div class="loop-arrow">→</div>
        <div class="loop-step accent-r reveal"><span class="ln mono">02</span><h3>Self-play match</h3><p>Home policy vs. a resumed opponent carrying an adversarial embedding.</p></div>
        <div class="loop-arrow">→</div>
        <div class="loop-step accent-g reveal"><span class="ln mono">03</span><h3>Per-step reward</h3><p>Score real events plus tactical shaping — the learning signal.</p></div>
        <div class="loop-arrow">→</div>
        <div class="loop-step accent-g reveal"><span class="ln mono">04</span><h3>Update</h3><p>PPO actor-critic and, periodically, the evolutionary population.</p></div>
        <div class="loop-arrow">→</div>
        <div class="loop-step accent-b reveal"><span class="ln mono">05</span><h3>Promotion gate</h3><p>Min fitness, max conceded, play quality — pass it, and become the champion.</p></div>
      </div>
      <p class="mono-note reveal" style="text-align:center; margin-top:24px;">↺ the promoted policy resumes as the next match’s opponent — co-evolution, not a fixed target</p>
    </div>
  </section>

  <hr class="hr" />

  <!-- REWARD -->
  <section class="section">
    <div class="wrap">
      <div class="split">
        <div class="reveal">
          <p class="eyebrow">Reward design</p>
          <h2>Grounded in real football, shaped with care</h2>
          <p>
            Reward hacking is the failure mode of RL, so Akrion anchors the signal in
            events that actually matter — goals, completed passes, shots, chains — and
            layers tactical shaping and an optional pitch-value term on top, each gated so
            it can be measured rather than trusted blindly.
          </p>
          <p class="mono-note">Illustrative signal composition — weights are tuned continuously, not fixed here.</p>
        </div>
        <div class="reward-stack reveal">
          {reward.map((r) => (
            <div class={`rw ${r.hot ? 'hot' : ''}`}>
              <span class="rw-k mono">{r.k}</span>
              <span class="rw-d">{r.d}</span>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <hr class="hr" />

  <!-- LEARNERS -->
  <section class="section">
    <div class="wrap">
      <div class="reveal" style="max-width:720px; margin-bottom:44px;">
        <p class="eyebrow">The learners</p>
        <h2>A stack of models, each learning one thing well</h2>
        <p class="lede">
          Not one giant network — a coordinated set of learned components. Actor and
          critic drive core decisions; specialists sharpen individual skills; evolution
          and retrieval handle what gradients alone can’t.
        </p>
      </div>
      <div class="grid grid-3">
        {learners.map((x) => (
          <article class={`card accent-${x.c} reveal`}>
            <span class="topbar"></span>
            <h3>{x.t}</h3>
            <p>{x.d}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <hr class="hr" />

  <!-- CURRICULUM -->
  <section class="section">
    <div class="wrap">
      <div class="reveal" style="max-width:720px; margin-bottom:34px;">
        <p class="eyebrow">Curriculum</p>
        <h2>Learn to walk before learning to win</h2>
        <p class="lede">Skill is built in stages. Each stage gates the next, so the policy masters fundamentals before it is asked to solve a full 11-v-11 match.</p>
      </div>
      <div class="curriculum reveal">
        {curriculum.map((s, i) => (
          <>
            <span class="cstage">{s}</span>
            {i < curriculum.length - 1 && <span class="csep">→</span>}
          </>
        ))}
      </div>
    </div>
  </section>

  <hr class="hr" />

  <!-- OPTIMAL + ADAPT -->
  <section class="section">
    <div class="wrap">
      <div class="two-up">
        <div class="card accent-g big reveal">
          <span class="topbar"></span>
          <p class="eyebrow" style="margin-bottom:10px;">Toward optimal</p>
          <h3>Learning reaches optimal control</h3>
          <p>
            Formation LP and MPC give provably-good structure. Reinforcement learning
            fills the gap the math can’t close — judgment under uncertainty — pushing the
            system from competent toward optimal, one promotion at a time.
          </p>
        </div>
        <div class="card accent-r big reveal">
          <span class="topbar"></span>
          <p class="eyebrow" style="margin-bottom:10px;">Staying optimal</p>
          <h3>Evolution breaks the ceiling</h3>
          <p>
            Gradient methods plateau in local optima. Genetic search — mutation,
            crossover, elitism over a policy population — perturbs the system out of those
            traps, and adapts it to opponents and styles it was never trained on.
          </p>
        </div>
      </div>

      <div class="cta-panel reveal">
        <h2>Optimal isn't a finish line — it's a moving target the engine keeps chasing.</h2>
        <div class="cta" style="justify-content:center;">
          <a class="btn btn-primary" href={`${base}engine`}>Inside the engine</a>
          <a class="btn btn-ghost" href={base}>Back to overview</a>
          <a class="btn btn-ghost" href="https://github.com/akrion-sim" target="_blank" rel="noopener">GitHub ↗</a>
        </div>
      </div>
    </div>
  </section>
</Base>

<style>
  .head h1 { max-width: 18ch; }
  .grad { background: linear-gradient(100deg, var(--green-bright), var(--blue-bright)); -webkit-background-clip: text; background-clip: text; color: transparent; }
  .head .lede { margin-top: 18px; }

  .loop { display: flex; align-items: stretch; gap: 10px; flex-wrap: wrap; justify-content: center; }
  .loop-step { flex: 1 1 180px; min-width: 170px; padding: 20px; border: 1px solid var(--line); border-radius: var(--radius); background: linear-gradient(180deg, var(--panel), var(--bg-2)); border-top: 3px solid var(--a); }
  .loop-step .ln { color: var(--ab); font-size: 0.82rem; font-weight: 700; }
  .loop-step h3 { font-size: 1.02rem; margin: 6px 0; }
  .loop-step p { font-size: 0.86rem; color: var(--ink-soft); margin: 0; }
  .loop-arrow { display: grid; place-items: center; color: var(--ink-dim); font-size: 1.2rem; }
  @media (max-width: 820px) { .loop-arrow { display: none; } }

  .split { display: grid; grid-template-columns: 1fr 1fr; gap: 44px; align-items: center; }
  @media (max-width: 880px) { .split { grid-template-columns: 1fr; gap: 28px; } }
  .split p { color: var(--ink-soft); }

  .reward-stack { display: grid; gap: 12px; }
  .rw { display: grid; grid-template-columns: 160px 1fr; gap: 16px; align-items: center; padding: 16px 18px; border: 1px solid var(--line); border-radius: 12px; background: var(--bg-2); }
  .rw-k { font-size: 0.78rem; text-transform: uppercase; letter-spacing: 0.08em; color: var(--ink-dim); }
  .rw-d { color: var(--ink-soft); font-size: 0.92rem; }
  .rw.hot { border-color: color-mix(in srgb, var(--green) 45%, var(--line)); background: color-mix(in srgb, var(--green) 9%, var(--bg-2)); }
  .rw.hot .rw-k { color: var(--green-bright); }
  @media (max-width: 520px) { .rw { grid-template-columns: 1fr; gap: 4px; } }

  .curriculum { display: flex; flex-wrap: wrap; align-items: center; gap: 10px; }
  .cstage { font-family: var(--font-mono); font-size: 0.9rem; padding: 10px 16px; border: 1px solid var(--line); border-radius: 999px; background: linear-gradient(180deg, var(--panel), var(--bg-2)); color: var(--ink); }
  .cstage:first-child { border-color: color-mix(in srgb, var(--blue) 45%, var(--line)); }
  .cstage:last-child { border-color: color-mix(in srgb, var(--green) 50%, var(--line)); color: var(--green-bright); }
  .csep { color: var(--ink-dim); }

  .two-up { display: grid; grid-template-columns: 1fr 1fr; gap: 20px; margin-bottom: 48px; }
  @media (max-width: 780px) { .two-up { grid-template-columns: 1fr; } }
  .big { padding: 32px; }
  .big h3 { font-size: 1.3rem; }
  .big p { color: var(--ink-soft); }

  .cta-panel { text-align: center; padding: 52px 32px; border: 1px solid var(--line); border-radius: var(--radius-lg);
    background: radial-gradient(600px 300px at 30% 0%, rgba(34,197,94,0.14), transparent 60%), radial-gradient(600px 300px at 80% 100%, rgba(239,68,68,0.12), transparent 60%), linear-gradient(180deg, var(--panel), var(--bg-2)); }
  .cta-panel h2 { max-width: 24ch; margin: 0 auto 24px; }
</style>
